#!/bin/bash

# Optional company-specific ~/.profile.d/company/<name>/ snippets.
# NVIDIA: loaded when any of these match:
#   - FQDN from hostname ends with .nvidia.com (domain-joined style)
#   - Resolver search / nameserver config mentions nvidia.com (common when
#     hostname -f is only an asset tag, e.g. DC9F9TW59T on macOS)
#   - Explicit opt-in: mkdir -p ~/.config/dotfiles/company
#     && touch ~/.config/dotfiles/company/nvidia

_company_profile_root="${HOME}/.profile.d/company"

_nvidia_dns_config_looks_corporate() {
	# macOS: system resolver state (search domains, etc.)
	if [ "$(uname -s)" = "Darwin" ]; then
		if scutil --dns 2>/dev/null | grep -qiE 'nvidia\.com'; then
			return 0
		fi
	fi
	# Linux and others: search/domain lines from DHCP/VPN
	if [ -r /etc/resolv.conf ]; then
		if grep -qiE 'nvidia\.com' /etc/resolv.conf; then
			return 0
		fi
	fi
	return 1
}

_should_load_nvidia_company_profile() {
	local fqdn
	fqdn=$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo "")
	case "$fqdn" in
	*.nvidia.com) return 0 ;;
	esac
	if _nvidia_dns_config_looks_corporate; then
		return 0
	fi
	if [ -f "${HOME}/.config/dotfiles/company/nvidia" ]; then
		return 0
	fi
	return 1
}

if _should_load_nvidia_company_profile; then
	if [ -f "${_company_profile_root}/nvidia/vault" ]; then
		# shellcheck source=/dev/null
		source "${_company_profile_root}/nvidia/vault"
	fi
fi

unset -f _nvidia_dns_config_looks_corporate
unset -f _should_load_nvidia_company_profile
unset _company_profile_root
